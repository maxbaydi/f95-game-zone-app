{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": false,
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "ES2022",
    "types": ["node"],
    "skipLibCheck": true
  },
  "include": ["src/main/**/*.js", "src/shared/**/*.js", "test/**/*.test.js"]
}
